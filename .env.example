# Obtain a key from https://www.eia.gov/opendata/register.php
EIA_API_KEY=
EIA_BASE_URL=https://api.eia.gov/v2
GRID_REGION=PJM
DATA_START_DATE=2023-01-01
DATA_END_DATE=2025-12-31
DATA_DIR=data
DATA_QUALITY_DIR=artifacts/data_quality
DUCKDB_PATH=data/gridmind.duckdb
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=mlartifacts
MLFLOW_ENABLED=true
LOG_LEVEL=INFO
MISSING_DEMAND_POLICY=error
FORECAST_HORIZON=24
VALIDATION_WINDOWS=5
VALIDATION_STEP_SIZE=24
TUNING_WINDOWS=4
OPTUNA_TRIALS=20
OPTUNA_TIMEOUT_SECONDS=
PRIMARY_SELECTION_METRIC=wape
MODEL_RANDOM_SEED=42
MODEL_N_JOBS=-1
ENABLE_MLFLOW=true
MLFLOW_EXPERIMENT_NAME=gridmind-demand-forecasting
MLFLOW_MODEL_NAME=gridmind-demand-forecast
MLFLOW_REGISTER_MODEL=true
MODEL_PROMOTION_THRESHOLD=0.0
SHAP_SAMPLE_SIZE=2000
WEATHER_PROVIDER=open_meteo
WEATHER_BASE_URL=https://archive-api.open-meteo.com/v1/archive
WEATHER_FORECAST_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_TIMEZONE=UTC
WEATHER_CACHE_DIR=data/weather
WEATHER_REQUEST_TIMEOUT_SECONDS=30
WEATHER_MAX_RETRIES=3
GRID_LOCATION_CONFIG=configs/grid_locations.yaml
WEATHER_FEATURES_ENABLED=true
WEATHER_LAGS=1,3,6,12,24
WEATHER_ROLLING_WINDOWS=3,6,12,24
RENEWABLE_TARGETS=solar_generation_mw,wind_generation_mw
NET_LOAD_ENABLED=true
DEMAND_WEATHER_MODEL_NAME=gridmind-weather-demand-forecast
SOLAR_MODEL_NAME=gridmind-solar-generation-forecast
WIND_MODEL_NAME=gridmind-wind-generation-forecast
TOTAL_RENEWABLE_MODEL_NAME=gridmind-total-renewable-generation-forecast
NET_LOAD_MODEL_NAME=gridmind-net-load-forecast
